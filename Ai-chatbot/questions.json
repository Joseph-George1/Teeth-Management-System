  "Q3C": {
    "id": "Q3C",
    "text_en": "Where is the hole or dark spot located?",
    "text_ar": "الخرم أو البقعة دي مكانها فين؟",
    "options": [
      { "id": "C1a", "text_en": "On a front tooth (shows when I smile)", "text_ar": "في سنة قدامية (بتبان وأنا بضحك)" },
      { "id": "C1b", "text_en": "On a back tooth (used for chewing)", "text_ar": "في ضرس ورا (بمضغ عليه)" }
