      { "id": "D1", "text_en": "Large break — most of the tooth structure is damaged", "text_ar": "كسر كبير أغلب السنة متضررة" },
      { "id": "D2", "text_en": "Just a small hole or minor chip", "text_ar": "مجرد خرم صغير أو حتة صغيرة" },
      { "id": "D3", "text_en": "Something else", "text_ar": "حاجة تانية" }
    ]
  },
  "Q2E": {
    "id": "Q2E",
    "text_en": "What do you need specifically?",
    "text_ar": "محتاج ايه بالظبط؟",
