  "Q1": {
    "id": "Q1",
    "text_en": "What is the problem?",
    "text_ar": "ما هي المشكلة؟",
    "options": [
      { "id": "A", "text_en": "My tooth hurts", "text_ar": "أسناني تؤلمني" },
      { "id": "B", "text_en": "My teeth are crooked or for a child", "text_ar": "أسناني معوجة أو للطفل" },
      { "id": "C", "text_en": "I'm missing a tooth", "text_ar": "لدي سن مفقود" },
      { "id": "D", "text_en": "My tooth is broken", "text_ar": "سني مكسور" },
      { "id": "E", "text_en": "Cleaning, extraction or checkup", "text_ar": "تنظيف، خلع أو فحص" },
      { "id": "F", "text_en": "Something else", "text_ar": "شيء آخر" }
    ]
  },
  "Q2A": {
    "id": "Q2A",
    "text_en": "Describe the pain: Is it throbbing, constant, or do you have swelling?",
    "text_ar": "صف الألم: هل هو نابض، مستمر، أو لديك انتفاخ؟",
    "options": [
      { "id": "A1", "text_en": "A little sensitive (not too bad)", "text_ar": "حساسية خفيفة (ليست سيئة جدًا)" },
      { "id": "A2", "text_en": "Really hurts (maybe swollen too)", "text_ar": "يؤلم كثيرًا (ربما منتفخ أيضًا)" }
    ]
  },
  "Q3A": {
    "id": "Q3A",
    "text_en": "Can you see a hole or dark spot on your tooth?",
    "text_ar": "هل ترى ثقب أو بقعة سوداء على سنك؟",
    "options": [
      { "id": "A1a", "text_en": "Yes, I can see it", "text_ar": "نعم، أراه" },
      { "id": "A1b", "text_en": "No, nothing visible", "text_ar": "لا، لا شيء مرئي" }
    ]
  },
  "Q4A": {
    "id": "Q4A",
    "text_en": "Describe the pain further:",
    "text_ar": "صف الألم أكثر:",
    "options": [
      { "id": "A2a", "text_en": "Throbbing pain, swelling, or pain at night", "text_ar": "ألم نابض، انتفاخ، أو ألم في الليل" },
      { "id": "A2b", "text_en": "Sharp pain when biting or other", "text_ar": "ألم حاد عند العض أو غيره" }
    ]
  },
  "Q2B": {
    "id": "Q2B",
    "text_en": "Is this for an adult or a child?",
    "text_ar": "هل هذا لشخص بالغ أم طفل؟",
    "options": [
      { "id": "B1", "text_en": "Adult", "text_ar": "بالغ" },
      { "id": "B2", "text_en": "Child", "text_ar": "طفل" }
    ]
  },
  "Q2C": {
    "id": "Q2C",
    "text_en": "How many teeth are missing? Do you want something permanent?",
    "text_ar": "كم سن مفقود؟ هل تريد شيئًا دائمًا؟",
    "options": [
      { "id": "C1", "text_en": "Just one tooth, want something permanent", "text_ar": "سن واحد فقط، أريد شيئًا دائمًا" },
      { "id": "C2", "text_en": "Multiple teeth, or prefer removable", "text_ar": "عدة أسنان، أو أفضل شيئًا قابلًا للإزالة" }
    ]
  },
  "Q2D": {
    "id": "Q2D",
    "text_en": "How bad is the damage?",
    "text_ar": "ما مدى سوء الضرر؟",
    "options": [
      { "id": "D1", "text_en": "Can probably be fixed with a cap", "text_ar": "يمكن إصلاحه بتاج على الأرجح" },
      { "id": "D2", "text_en": "Just a small hole", "text_ar": "ثقب صغير فقط" },
      { "id": "D3", "text_en": "Something else", "text_ar": "شيء آخر" }
    ]
  },
  "Q2E": {
    "id": "Q2E",
    "text_en": "What do you need specifically?",
    "text_ar": "ماذا تحتاج بالتحديد؟",
    "options": [
      { "id": "E1", "text_en": "Cleaning and Whitening", "text_ar": "تنظيف وتبييض" },
      { "id": "E2", "text_en": "Tooth Extraction", "text_ar": "خلع أسنان" },
      { "id": "E3", "text_en": "Something else", "text_ar": "شيء آخر" }
    ]
