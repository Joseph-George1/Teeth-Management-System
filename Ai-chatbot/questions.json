  "Q2A": {
    "id": "Q2A",
    "text_en": "Describe the pain: Is it throbbing, constant, or do you have swelling?",
    "text_ar": "أوصف الألم: هل هو بينبض، مستمر، ولا في ورم؟",
    "options": [
      { "id": "A1", "text_en": "A little sensitive (not too bad)", "text_ar": "حساسية خفيفة (مش أوي)" },
      { "id": "A2", "text_en": "Really hurts (maybe swollen too)", "text_ar": "بيوجع أوي (ويمكن وارم كمان)" }
    ]
  },
  "Q3A": {
    "id": "Q3A",
    "text_en": "Can you see a hole or dark spot on your tooth?",
    "text_ar": "شايف خرم أو بقعة سودة على سنتك؟",
    "options": [
      { "id": "A1a", "text_en": "Yes, I can see it", "text_ar": "أيوة، شايفها" },
      { "id": "A1b", "text_en": "No, nothing visible", "text_ar": "لأ، مفيش حاجة باينة" }
    ]
  },
  "Q3B": {
    "id": "Q3B",
    "text_en": "When does the tooth hurt the most?",
    "text_ar": "امتى السنة بتوجعك أكتر حاجة؟",
    "options": [
      { "id": "B1a", "text_en": "With cold or hot drinks", "text_ar": "مع المشروبات الساقعة أو السخنة" },
      { "id": "B1b", "text_en": "When biting down", "text_ar": "وقت العض" },
      { "id": "B1c", "text_en": "Constant pain or something else", "text_ar": "وجع مستمر أو حاجة تانية" }
    ]
  },
  "Q4A": {
    "id": "Q4A",
    "text_en": "Describe the pain further:",
    "text_ar": "أوصف الألم أكتر:",
    "options": [
      { "id": "A2a", "text_en": "Throbbing pain, swelling, or pain at night", "text_ar": "وجع بينبض، ورم، أو وجع بالليل" },
      { "id": "A2b", "text_en": "Sharp pain when biting down", "text_ar": "وجع جامد وأنا بعض" }
    ]
  },
  "Q2B": {
    "id": "Q2B",
    "text_en": "Is this for an adult or a child?",
    "text_ar": "ده لكبير ولا لطفل؟",
