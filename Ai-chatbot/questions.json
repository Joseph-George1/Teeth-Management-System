  "Q3D": {
    "id": "Q3D",
    "text_en": "Is the broken tooth visible when you smile?",
    "text_ar": "هل السنة المكسورة بتبان وأنت بتضحك؟",
    "options": [
      { "id": "D2a", "text_en": "Yes, it's a front tooth", "text_ar": "أيوة، سنة قدامية" },
      { "id": "D2b", "text_en": "No, it's hidden in the back", "text_ar": "لأ، مستخبية ورا" }
