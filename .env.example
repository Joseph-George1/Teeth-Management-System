# =============================================================================
# TEETH MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update the values for your environment.
# This file is used by all services (Python, Shell scripts) for configuration.
#
# Location: .env (root directory)
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Oracle Database connection details
# Format: jdbc:oracle:thin:@hostname:port/SERVICE_NAME
# Example: jdbc:oracle:thin:@localhost:1521/orclpdb
#
# The DB_URL is parsed by:
# - forgetpassword.py: Extracts connection parameters for oracledb.connect()
# - Notification/config.py: Uses format for SQLAlchemy oracle+oracledb:// URL
# - Backend (Spring Boot): Uses directly via --spring.datasource.url
# - Backup/Restore scripts: Used for sqlplus connections
#
DB_URL=jdbc:oracle:thin:@localhost:1521/orclpdb
DB_USERNAME=hr
DB_PASSWORD=hr

# =============================================================================
# API SERVICE PORTS
# =============================================================================
# Configure ports for different microservices
#
WEB_UI_PORT=5173
BACKEND_PORT=8080
API_PORT=5010
LOGIN_API_PORT=5000
OTP_PORT=8000
PROXY_PORT=5173
FORGET_PASSWORD_PORT=7000
NOTIFICATION_PORT=9000

# =============================================================================
# BACKEND URLs (for inter-service communication)
# =============================================================================
#
BACKEND_URL=http://localhost:8080
AI_URL=http://127.0.0.1:5010
OTP_URL=http://127.0.0.1:8000
PROXY_URL=http://127.0.0.1:5173
OTP_SERVICE_URL=http://127.0.0.1:8000

# =============================================================================
# ADMIN DASHBOARD CONFIGURATION
# =============================================================================
#
DASHBOARD_PORT=6500

# For production, set a fixed SECRET_KEY to maintain session persistence
# across service restarts. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-fixed-secret-key-here

# Custom admin prefix for obfuscation (prevents crawler discovery)
# Default: /api/tms-mng-x7k2p9q3
# ADMIN_PREFIX=/your-custom-path

# =============================================================================
# ORACLE DATABASE PATHS (for backup/restore scripts)
# =============================================================================
# These are primarily used by backup/backup.sh and backup/restore.sh
#
ORACLE_HOME=/opt/oracle/product/21c/dbhomeXE
DB_HOST=localhost
DB_PORT=1521
DB_ORACLE_SID=XE

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
#
BACKUP_ROOT_PATH=/backup
BACKUP_RETENTION_DAYS=7

# =============================================================================
# DISCORD CONFIGURATION
# =============================================================================
#
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_WEBHOOK_URL=
ALLOWED_USER_IDS=

# =============================================================================
# FIREBASE CONFIGURATION (if using Notification service)
# =============================================================================
#
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/firebase-service-account.json

# =============================================================================
# WHATSAPP CONFIGURATION (WAHA API)
# =============================================================================
# WAHA (WhatsApp HTTP API) for direct WhatsApp messaging integration
# 
# WAHA_API_URL:  URL where WAHA service is running
# WAHA_API_KEY:  API key for authentication with WAHA service
# WAHA_SESSION:  Session name to use in WAHA
# WHATSAPP_PHONES: Space-separated list of WhatsApp phone numbers (without +) to monitor/send to
#
WAHA_API_URL=http://127.0.0.1:3000
WAHA_API_KEY=
WAHA_SESSION=default
WHATSAPP_PHONES=

# =============================================================================
# NOTIFICATION SERVICE CONFIGURATION (FastAPI Microservice)
# =============================================================================
# Configuration for the Notification microservice (Notification/config.py)
#
# Retry configuration for failed notifications
MAX_RETRIES=3
RETRY_BACKOFF_MULTIPLIER=2.0
INITIAL_RETRY_DELAY_MS=1000

# Queue and cache configuration
QUEUE_CHECK_INTERVAL=30
TEMPLATE_CACHE_TTL=300

# FCM (Firebase Cloud Messaging) limits
MAX_DEVICES_PER_USER=5

# Firebase credentials path (relative to project root)
FIREBASE_KEY_PATH=./Notification/firebase-key.json

# Notification service environment (production/development/staging)
NOTIFICATION_ENVIRONMENT=production

# =============================================================================
# EMAIL CONFIGURATION (SMTP) - Notification Service
# =============================================================================
# Used by Notification service for email delivery
# Set ENABLE_EMAIL=true to activate email notifications
#
ENABLE_EMAIL=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SENDER_EMAIL=noreply@dentalsystem.com
SENDER_PASSWORD=

# =============================================================================
# GOOGLE API CONFIGURATION
# =============================================================================
# Google APIs for AI chatbot, Generative AI, etc.
#
GOOGLE_API_KEY=

# =============================================================================
# ADMIN DASHBOARD CONFIGURATION
# =============================================================================
# Optional admin panel settings
#
DASHBOARD_PORT=6500

# For production, set a fixed SECRET_KEY to maintain session persistence
# across service restarts. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-fixed-secret-key-here

# Custom admin prefix for obfuscation (prevents crawler discovery)
# Default: /api/tms-mng-x7k2p9q3
# ADMIN_PREFIX=/your-custom-path

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
#
LOG_DIR=$HOME/Teeth-Management-System/logs
LOG_LEVEL=INFO
LOG_FILE=$HOME/Teeth-Management-System/logs/application.log

# =============================================================================
# SYSTEM PATHS CONFIGURATION
# =============================================================================
# Project directory paths (normally auto-detected, but can be overridden)
#
# SOURCE_ROOT_PATH=$HOME/Teeth-Management-System
# ASTART_PATH=astart

# =============================================================================
# NOTES
# =============================================================================
# - Do NOT commit .env to version control (already in .gitignore)
# - All Python scripts use python-dotenv to load this file
# - Shell scripts source this file directly using: source .env
# - The astart launcher loads this file from: $HOME/Teeth-Management-System/.env
